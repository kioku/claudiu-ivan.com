{
  "name": "astro-ci-website",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:network": "astro dev --host",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "preview:network": "astro preview --host",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playground:test": "pnpm -r --filter './playground/*' test",
    "playground:test:watch": "pnpm -r --filter './playground/*' test:watch",
    "playground:build": "pnpm -r --filter './playground/*' build"
  },
  "workspaces": [
    "playground/*"
  ],
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.39.2",
    "@fontsource/archivo": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "astro": "^5.17.3",
    "astro-eslint-parser": "^1.3.0",
    "clsx": "^2.1.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "globals": "^16.5.0",
    "katex": "^0.16.28",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.3"
  }
}
