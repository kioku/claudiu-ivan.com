---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import CollectionListItem from "@components/CollectionListItem.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, HOME } from "@consts";

const writing = (await getCollection("writing"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section>
        <article class="space-y-6">
          <div class="space-y-4">
            <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-black dark:text-white">
              {SITE.NAME}
            </h1>
            <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-black/40 dark:text-white/40">
              Principal System Architect
            </h2>
          </div>
          <p class="text-base leading-relaxed text-gray-600 dark:text-gray-400 max-w-md">
            This is where I explore the intersection of theory and practice in building robust software.
          </p>
        </article>
      </section>

      <hr class="border-gray-200 dark:border-gray-700" />

      <section class="space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h2 class="text-xl font-semibold text-black dark:text-white">
            Writing
          </h2>
          <a href="/writing" class="text-sm text-gray-500 dark:text-gray-500 hover:text-black dark:hover:text-white transition-colors">
            View all →
          </a>
        </div>
        <ul class="flex flex-col gap-4">
          {writing.map(post => (
            <li>
              <CollectionListItem entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <hr class="border-gray-200 dark:border-gray-700" />

      <section class="space-y-4">
        <p class="text-base leading-relaxed text-gray-600 dark:text-gray-400">
          I partner with a select number of organizations on their most critical technical challenges.
          If you are building a data-intensive platform and require a principal-level architect with a
          track record of delivering at scale, I would be pleased to discuss how I can help.
        </p>
        <a
          href="https://softwarefoundry.ch"
          target="_blank"
          rel="noopener noreferrer"
          id="visit-software-foundry"
          class="inline-flex items-center gap-2 text-black dark:text-white font-semibold hover:text-gray-600 dark:hover:text-gray-300 transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black dark:focus-visible:outline-white"
        >
          Software Foundry
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </section>
    </div>
  </Container>
</PageLayout>
